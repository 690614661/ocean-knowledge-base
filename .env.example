# 海洋生物知识库 — 环境变量配置示例
# 复制为 .env 并填写真实值

# AI 供应商（bailian / deepseek）
AI_PROVIDER=bailian

# 阿里云百炼 API Key（通义千问）
# 获取地址: https://bailian.console.aliyun.com/
BAILIAN_API_KEY=your-bailian-api-key

# DeepSeek API Key（备选）
DEEPSEEK_API_KEY=your-deepseek-api-key

# MySQL 密码
MYSQL_PASSWORD=smj041209

# JWT 签名密钥
JWT_SECRET=ocean_knowledge_jwt_secret_2026

# 七牛云对象存储
FILE_STORAGE_TYPE=qiniu
QINIU_ACCESS_KEY=your-qiniu-access-key
QINIU_SECRET_KEY=your-qiniu-secret-key
QINIU_BUCKET=ocean-knowledge-base
QINIU_DOMAIN=https://cdn.your-domain.com
QINIU_REGION=southchina
